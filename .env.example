# ──────────────────────────────────────────────────────────────────────
#  PGU-TUB — Variáveis de ambiente (exemplo)
#  Copiar para .env e preencher com valores reais.
# ──────────────────────────────────────────────────────────────────────

# ─── Data Warehouse (PostgreSQL analítico) ───
DW_USER=pgu_dw
DW_PASSWORD=CHANGE_ME
DW_NAME=pgu_datawarehouse

# ─── Tools DB (PostgreSQL partilhado para Airflow / Keycloak / Metabase) ───
TOOLS_DB_USER=tools_admin
TOOLS_DB_PASSWORD=CHANGE_ME

# ─── MongoDB (histórico bruto / audit) ───
MONGO_USER=pgu_mongo
MONGO_PASSWORD=CHANGE_ME

# ─── Airflow ───
AIRFLOW_DB_NAME=airflow_db
AIRFLOW_FERNET_KEY=CHANGE_ME
AIRFLOW_SECRET_KEY=CHANGE_ME
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=CHANGE_ME

# ─── Keycloak ───
KEYCLOAK_DB_NAME=keycloak_db
IAM_ADMIN_USER=admin
IAM_ADMIN_PASSWORD=CHANGE_ME

# ─── Metabase ───
METABASE_DB_NAME=metabase_db

# ─── NiFi ───
NIFI_USERNAME=admin
NIFI_PASSWORD=CHANGE_ME

# ─── API Key Interna (machine-to-machine: NiFi, Simulador, Airflow) ───
PGU_INTERNAL_API_KEY=CHANGE_ME

# ─── SMTP (opcional — alertas funcionam sem isto) ───
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USERNAME=
#SMTP_PASSWORD=
#SMTP_AUTH=true
#SMTP_STARTTLS=true

# ─── Alertas Críticos ───
PGU_ALERTAS_COOLDOWN=5
#PGU_ALERTAS_EMAIL=admin@example.com
PGU_ALERTAS_EMAIL_FROM=sistema@tub.pt
